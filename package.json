{
  "name": "vstr-bridge",
  "displayName": "VSTR Bridge",
  "description": "Bridge server for VSCode Terminal Runner CLI",
  "repository": {
    "type": "git",
    "url": "https://github.com/DieGopherLT/VSTR-Bridge"
  },
  "version": "0.1.1",
  "publisher": "DieGopherLT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vscr-bridge.status",
        "title": "VSTR Bridge: Show Status"
      }
    ],
    "configuration": {
      "title": "VSTR Bridge",
      "properties": {
        "vstrBridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the bridge server when VSCode opens"
        },
        "vstrBridge.port": {
          "type": "number",
          "default": 0,
          "description": "Port for the bridge server (0 = auto-select)"
        },
        "vstrBridge.security.strictMode": {
          "type": "boolean",
          "default": true,
          "description": "Enable strict security mode"
        },
        "vstrBridge.security.additionalSafeCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional commands to consider safe"
        },
        "vstrBridge.security.maxRequestsPerMinute": {
          "type": "number",
          "default": 30,
          "description": "Maximum requests per minute per client"
        },
        "vstrBridge.security.auditLogging": {
          "type": "boolean",
          "default": true,
          "description": "Enable security audit logging"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "install-local": "code --install-extension vstr-bridge-$npm_package_version.vsix",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "test:unit": "jest",
    "test:unit:coverage": "jest --coverage",
    "test:unit:watch": "jest --watch",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/jest": "^30.0.0",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vscode/test-electron": "^2.2.0",
    "@vscode/vsce": "^2.19.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^4.9.3"
  }
}
